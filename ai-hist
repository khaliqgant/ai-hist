#!/usr/bin/env python3
"""
ai-hist: Sync and search AI CLI conversation history in SQLite.

Supports Claude Code and Codex CLI out of the box.
Zero dependencies — Python 3.8+ standard library only.
"""

import argparse
import json
import os
import sqlite3
import sys
import time
import urllib.request
import urllib.error
from pathlib import Path

# --- Configuration -----------------------------------------------------------

DEFAULT_DB = os.path.join(os.environ.get("XDG_DATA_HOME", str(Path.home() / ".local" / "share")), "ai-hist", "ai-history.db")
DB_PATH = Path(os.environ.get("AI_HIST_DB", DEFAULT_DB))
STATE_PATH = DB_PATH.parent / ".sync-state.json"

SOURCES = {
    "claude": Path.home() / ".claude" / "history.jsonl",
    "codex": Path.home() / ".codex" / "history.jsonl",
}

CURSOR_ROOT = Path.home() / ".cursor" / "projects"

# --- Schema ------------------------------------------------------------------

SCHEMA = """\
CREATE TABLE IF NOT EXISTS history (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    source TEXT NOT NULL,
    session_id TEXT,
    project TEXT,
    prompt TEXT NOT NULL,
    timestamp_ms INTEGER NOT NULL,
    UNIQUE(source, timestamp_ms, prompt)
);
CREATE VIRTUAL TABLE IF NOT EXISTS history_fts USING fts5(
    prompt, project, content='history', content_rowid='id'
);
CREATE TRIGGER IF NOT EXISTS history_ai AFTER INSERT ON history BEGIN
    INSERT INTO history_fts(rowid, prompt, project)
    VALUES (new.id, new.prompt, new.project);
END;
"""

# --- Parsers -----------------------------------------------------------------

def parse_claude(line: str):
    """Parse a Claude Code history.jsonl line."""
    obj = json.loads(line)
    display = obj.get("display", "").strip()
    if not display:
        return None
    return {
        "source": "claude",
        "session_id": obj.get("sessionId"),
        "project": obj.get("project"),
        "prompt": display,
        "timestamp_ms": obj.get("timestamp", 0),
    }


def parse_codex(line: str):
    """Parse a Codex CLI history.jsonl line."""
    obj = json.loads(line)
    text = obj.get("text", "").strip()
    if not text:
        return None
    return {
        "source": "codex",
        "session_id": obj.get("session_id"),
        "project": None,
        "prompt": text,
        "timestamp_ms": int(obj.get("ts", 0) * 1000),
    }


PARSERS = {
    "claude": parse_claude,
    "codex": parse_codex,
}


def parse_cursor_line(line: str):
    """Extract a user prompt from a cursor agent-transcripts jsonl line.

    Cursor lines have shape `{role, message: {content: [{type, text}, ...]}}`
    and carry no per-line timestamp. User prompts are wrapped in
    `<user_query>...</user_query>`.
    """
    obj = json.loads(line)
    if obj.get("role") != "user":
        return None
    msg = obj.get("message") or {}
    content = msg.get("content")
    text = ""
    if isinstance(content, str):
        text = content
    elif isinstance(content, list):
        for c in content:
            if isinstance(c, dict) and c.get("type") == "text":
                text = c.get("text", "")
                break
    text = text.strip()
    if not text:
        return None
    if text.startswith("<user_query>") and text.endswith("</user_query>"):
        text = text[len("<user_query>"):-len("</user_query>")].strip()
    return text or None


def _decode_cursor_project(name: str) -> str:
    """Decode an encoded cursor project dir name back into a filesystem path."""
    return "/" + name.replace("-", "/")


def sync_cursor(conn: sqlite3.Connection, state: dict):
    """Sync user prompts from ~/.cursor/projects/*/agent-transcripts/."""
    if not CURSOR_ROOT.exists():
        return

    cursor_state = state.get("cursor", {})
    inserted = 0
    errors = 0
    files_seen = 0

    for project_dir in sorted(CURSOR_ROOT.iterdir()):
        if not project_dir.is_dir():
            continue
        ts_root = project_dir / "agent-transcripts"
        if not ts_root.is_dir():
            continue
        project_path = _decode_cursor_project(project_dir.name)
        for session_dir in sorted(ts_root.iterdir()):
            if not session_dir.is_dir():
                continue
            session_id = session_dir.name
            jsonl = session_dir / f"{session_id}.jsonl"
            if not jsonl.exists():
                continue
            files_seen += 1
            try:
                stat = jsonl.stat()
            except OSError:
                errors += 1
                continue
            offset = cursor_state.get(str(jsonl), 0)
            if offset >= stat.st_size:
                continue
            ts_ms = int(stat.st_mtime * 1000)
            try:
                with open(jsonl, "r", encoding="utf-8") as f:
                    f.seek(offset)
                    for line in f:
                        line = line.strip()
                        if not line:
                            continue
                        try:
                            text = parse_cursor_line(line)
                        except (json.JSONDecodeError, KeyError, TypeError):
                            errors += 1
                            continue
                        if not text:
                            continue
                        try:
                            cur = conn.execute(
                                "INSERT OR IGNORE INTO history "
                                "(source, session_id, project, prompt, timestamp_ms) "
                                "VALUES (?, ?, ?, ?, ?)",
                                ("cursor", session_id, project_path, text, ts_ms),
                            )
                            if cur.rowcount > 0:
                                inserted += 1
                        except sqlite3.Error:
                            errors += 1
            except OSError:
                errors += 1
                continue
            cursor_state[str(jsonl)] = stat.st_size

    conn.commit()
    state["cursor"] = cursor_state
    if files_seen:
        suffix = f" ({errors} errors)" if errors else ""
        print(f"  [cursor] +{inserted:,} rows from {files_seen} files{suffix}")

# --- Relaycast API -----------------------------------------------------------

RELAYCAST_BASE = os.environ.get("RELAYCAST_BASE_URL", "https://api.relaycast.dev")
RELAYCAST_API_KEY = os.environ.get("RELAYCAST_API_KEY", "")
RELAYCAST_WORKSPACE_ID = os.environ.get("RELAYCAST_WORKSPACE_ID", "")


def relaycast_get(path: str, params: dict = None) -> dict:  # pragma: no cover
    """Make a GET request to the Relaycast API."""
    url = f"{RELAYCAST_BASE}/v1/{path}"
    if params:
        qs = "&".join(f"{k}={v}" for k, v in params.items() if v is not None)
        if qs:
            url += f"?{qs}"
    req = urllib.request.Request(url, headers={
        "Authorization": f"Bearer {RELAYCAST_API_KEY}",
        "Accept": "application/json",
    })
    with urllib.request.urlopen(req, timeout=30) as resp:
        return json.loads(resp.read().decode())


def sync_relaycast(conn: sqlite3.Connection, state: dict):
    """Sync messages from Relaycast API into the history table."""
    if not RELAYCAST_API_KEY or not RELAYCAST_WORKSPACE_ID:
        return

    relay_state = state.get("relay", {})
    inserted = 0
    errors = 0

    try:
        # Sync channel messages
        resp = relaycast_get("channels")
        channels = resp.get("data", []) if resp.get("ok") else []

        for ch in channels:
            ch_name = ch.get("name", "")
            last_id = relay_state.get(f"ch:{ch_name}")
            params = {"limit": "100"}
            if last_id:
                params["after"] = last_id

            max_id = last_id
            while True:
                resp = relaycast_get(f"channels/{ch_name}/messages", params)
                messages = resp.get("data", []) if resp.get("ok") else []
                if not messages:
                    break
                for msg in messages:
                    row = _relay_msg_to_row(msg, f"#{ch_name}")
                    if row:
                        try:
                            cur = conn.execute(
                                "INSERT OR IGNORE INTO history "
                                "(source, session_id, project, prompt, timestamp_ms) "
                                "VALUES (:source, :session_id, :project, :prompt, :timestamp_ms)",
                                row,
                            )
                            if cur.rowcount > 0:
                                inserted += 1
                        except sqlite3.Error:
                            errors += 1
                    mid = msg.get("id", "")
                    if mid and (not max_id or mid > max_id):
                        max_id = mid
                # If we got fewer than limit, we're done
                if len(messages) < 100:
                    break
                params["after"] = messages[-1].get("id", "")

            if max_id:
                relay_state[f"ch:{ch_name}"] = max_id

        # Sync DM conversations
        try:
            resp = relaycast_get("dm/conversations/all")
            conversations = resp.get("data", []) if resp.get("ok") else []
        except urllib.error.HTTPError:
            conversations = []

        for conv in conversations:
            conv_id = conv.get("id", "")
            if not conv_id:
                continue
            last_id = relay_state.get(f"dm:{conv_id}")
            params = {"limit": "100"}
            if last_id:
                params["after"] = last_id

            max_id = last_id
            while True:
                resp = relaycast_get(f"dm/conversations/{conv_id}/messages", params)
                messages = resp.get("data", []) if resp.get("ok") else []
                if not messages:
                    break
                for msg in messages:
                    row = _relay_msg_to_row(msg, f"dm:{conv_id}")
                    if row:
                        try:
                            cur = conn.execute(
                                "INSERT OR IGNORE INTO history "
                                "(source, session_id, project, prompt, timestamp_ms) "
                                "VALUES (:source, :session_id, :project, :prompt, :timestamp_ms)",
                                row,
                            )
                            if cur.rowcount > 0:
                                inserted += 1
                        except sqlite3.Error:
                            errors += 1
                    mid = msg.get("id", "")
                    if mid and (not max_id or mid > max_id):
                        max_id = mid
                if len(messages) < 100:
                    break
                params["after"] = messages[-1].get("id", "")

            if max_id:
                relay_state[f"dm:{conv_id}"] = max_id

        conn.commit()
        state["relay"] = relay_state
        print(f"  [relay] +{inserted:,} rows" + (f" ({errors} errors)" if errors else ""))

    except (urllib.error.URLError, urllib.error.HTTPError, OSError) as e:
        print(f"  [relay] API error: {e}")
    except Exception as e:
        print(f"  [relay] error: {e}")


def _relay_msg_to_row(msg: dict, channel: str):
    """Convert a Relaycast message to a history row."""
    text = msg.get("text", "")
    if not text:
        return None
    sender = msg.get("from_name") or msg.get("from_id") or ""
    created_at = msg.get("created_at", "")
    # Parse ISO timestamp to ms
    ts_ms = _iso_to_ms(created_at) if created_at else 0
    # Prefix with sender for searchability
    prompt = f"[{sender}] {text}" if sender else text
    return {
        "source": "relay",
        "session_id": msg.get("thread_id") or channel,
        "project": RELAYCAST_WORKSPACE_ID,
        "prompt": prompt,
        "timestamp_ms": ts_ms,
    }


def _iso_to_ms(iso_str: str) -> int:
    """Parse ISO 8601 datetime string to milliseconds since epoch."""
    # Handle common formats: 2026-03-07T20:13:00.000Z or 2026-03-07T20:13:00Z
    iso_str = iso_str.rstrip("Z").split("+")[0]
    frac = 0
    if "." in iso_str:
        base, frac_str = iso_str.rsplit(".", 1)
        frac = int(frac_str.ljust(3, "0")[:3])
        iso_str = base
    try:
        t = time.strptime(iso_str, "%Y-%m-%dT%H:%M:%S")
    except ValueError:
        return 0
    return int(time.mktime(t)) * 1000 + frac


# --- Core --------------------------------------------------------------------

def init_db(conn: sqlite3.Connection):
    conn.executescript(SCHEMA)
    conn.execute("PRAGMA journal_mode=WAL")


def load_state() -> dict:
    if STATE_PATH.exists():
        return json.loads(STATE_PATH.read_text())
    return {}


def save_state(state: dict):
    STATE_PATH.parent.mkdir(parents=True, exist_ok=True)
    STATE_PATH.write_text(json.dumps(state, indent=2))


def fmt_row(id_, source, project, prompt, ts_ms, verbose=False):
    """Format a single row for display."""
    dt = time.strftime("%Y-%m-%d %H:%M", time.localtime(ts_ms / 1000))
    proj = f" [{project}]" if project else ""
    if verbose:
        display = prompt
    else:
        display = prompt[:120] + "..." if len(prompt) > 120 else prompt
        display = display.replace("\n", " ")
    return f"  #{id_:<5} {dt}  ({source}){proj}  {display}"


# --- Commands ----------------------------------------------------------------

def cmd_sync(args=None):
    """Import new entries from history files into SQLite."""
    DB_PATH.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(str(DB_PATH))
    init_db(conn)
    state = load_state()

    for name, path in SOURCES.items():
        if not path.exists():
            print(f"  [{name}] not found: {path} (skipped)")
            continue

        file_size = path.stat().st_size
        offset = state.get(name, 0)
        if offset >= file_size:
            print(f"  [{name}] up to date")
            continue

        print(f"  [{name}] syncing {file_size - offset:,} new bytes...")
        parser = PARSERS[name]
        inserted = 0
        errors = 0

        with open(path, "r", encoding="utf-8") as f:
            f.seek(offset)
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    row = parser(line)
                except (json.JSONDecodeError, KeyError, TypeError):
                    errors += 1
                    continue
                if row is None:
                    continue
                try:
                    cur = conn.execute(
                        "INSERT OR IGNORE INTO history "
                        "(source, session_id, project, prompt, timestamp_ms) "
                        "VALUES (:source, :session_id, :project, :prompt, :timestamp_ms)",
                        row,
                    )
                    if cur.rowcount > 0:
                        inserted += 1
                except sqlite3.Error:
                    errors += 1

        conn.commit()
        state[name] = file_size
        print(f"  [{name}] +{inserted:,} rows" + (f" ({errors} errors)" if errors else ""))

    # Sync Cursor agent transcripts (auto-discovered, no config needed)
    sync_cursor(conn, state)

    # Sync Relaycast (opt-in via env vars)
    sync_relaycast(conn, state)

    save_state(state)
    total = conn.execute("SELECT COUNT(*) FROM history").fetchone()[0]
    conn.close()
    print(f"  Total: {total:,} entries")


def cmd_search(args):
    """Full-text search across prompts."""
    conn = sqlite3.connect(str(DB_PATH))
    # Quote each term so hyphens/special chars are treated as literals by FTS5
    query = " ".join(f'"{t}"' for t in args.query)

    sql = (
        "SELECT h.id, h.source, h.project, h.prompt, h.timestamp_ms "
        "FROM history_fts f JOIN history h ON f.rowid = h.id "
        "WHERE history_fts MATCH ? "
    )
    params: list = [query]
    if args.source:
        sql += "AND h.source = ? "
        params.append(args.source)
    if args.project:
        sql += "AND h.project LIKE ? "
        params.append(f"%{args.project}%")
    sql += "ORDER BY h.timestamp_ms DESC LIMIT ?"
    params.append(args.limit)

    rows = conn.execute(sql, params).fetchall()
    conn.close()

    if not rows:
        print("No results.")
        return
    for row in rows:
        print(fmt_row(*row))


def cmd_recent(args):
    """Show N most recent entries."""
    conn = sqlite3.connect(str(DB_PATH))
    sql = "SELECT id, source, project, prompt, timestamp_ms FROM history "
    params: list = []
    wheres = []
    if args.source:
        wheres.append("source = ?")
        params.append(args.source)
    if args.project:
        wheres.append("project LIKE ?")
        params.append(f"%{args.project}%")
    if wheres:
        sql += "WHERE " + " AND ".join(wheres) + " "
    sql += "ORDER BY timestamp_ms DESC LIMIT ?"
    params.append(args.n)
    rows = conn.execute(sql, params).fetchall()
    conn.close()
    for row in rows:
        print(fmt_row(*row))


def cmd_show(args):
    """Show the full prompt for a given entry ID."""
    conn = sqlite3.connect(str(DB_PATH))
    row = conn.execute(
        "SELECT id, source, session_id, project, prompt, timestamp_ms "
        "FROM history WHERE id = ?",
        (args.id,),
    ).fetchone()
    if not row:
        conn.close()
        print(f"No entry with id {args.id}")
        return
    id_, source, session_id, project, prompt, ts_ms = row
    dt = time.strftime("%Y-%m-%d %H:%M:%S", time.localtime(ts_ms / 1000))
    print(f"  ID:        {id_}")
    print(f"  Source:    {source}")
    print(f"  Session:   {session_id or '(none)'}")
    print(f"  Project:   {project or '(none)'}")
    print(f"  Time:      {dt}")
    print(f"  Prompt:")
    print()
    print(prompt)

    # Hints
    print()
    if session_id:
        session_count = conn.execute(
            "SELECT COUNT(*) FROM history WHERE session_id = ?", (session_id,)
        ).fetchone()[0]
        print(f"  Session has {session_count} entries: ai-hist session {session_id}")
        if source == "claude" and project:
            print(f"  Resume:  cd {project} && claude --resume {session_id}")
        elif source == "codex" and session_id:
            print(f"  Resume:  codex resume {session_id}")
        elif source == "cursor":
            cmd = f"cursor-agent --resume={session_id}"
            if project:
                print(f"  Resume:  cd {project} && {cmd}")
            else:
                print(f"  Resume:  {cmd}")
    print(f"  Context: ai-hist context {id_}")
    conn.close()


def cmd_context(args):
    """Show entries around a given ID: same session + nearby in time."""
    conn = sqlite3.connect(str(DB_PATH))
    row = conn.execute(
        "SELECT id, source, session_id, project, timestamp_ms "
        "FROM history WHERE id = ?",
        (args.id,),
    ).fetchone()
    if not row:
        conn.close()
        print(f"No entry with id {args.id}")
        return
    id_, source, session_id, project, ts_ms = row

    # Same session
    if session_id:
        session_rows = conn.execute(
            "SELECT id, source, project, prompt, timestamp_ms "
            "FROM history WHERE session_id = ? ORDER BY timestamp_ms ASC",
            (session_id,),
        ).fetchall()
        if session_rows:
            print(f"  === Session {session_id} ({len(session_rows)} entries) ===\n")
            for r in session_rows:
                marker = " >>>" if r[0] == id_ else "    "
                print(f"{marker}{fmt_row(*r)}")
            print()

    # Nearby in time (±5 min), excluding same session
    window_ms = args.window * 60 * 1000
    nearby_sql = (
        "SELECT id, source, project, prompt, timestamp_ms "
        "FROM history WHERE timestamp_ms BETWEEN ? AND ? "
        "AND (session_id IS NULL OR session_id != ?) "
        "ORDER BY timestamp_ms ASC"
    )
    nearby_rows = conn.execute(
        nearby_sql, (ts_ms - window_ms, ts_ms + window_ms, session_id or "")
    ).fetchall()
    if nearby_rows:
        print(f"  === Nearby ({args.window}min window, other sessions) ===\n")
        for r in nearby_rows:
            print(f"    {fmt_row(*r)}")

    conn.close()


def cmd_session(args):
    """Show all prompts in a given session."""
    conn = sqlite3.connect(str(DB_PATH))
    rows = conn.execute(
        "SELECT id, source, project, prompt, timestamp_ms "
        "FROM history WHERE session_id = ? ORDER BY timestamp_ms ASC",
        (args.session_id,),
    ).fetchall()
    conn.close()
    if not rows:
        print(f"No entries for session {args.session_id}")
        return
    print(f"  Session {args.session_id} ({len(rows)} entries):\n")
    for row in rows:
        print(fmt_row(*row, verbose=args.full))


def cmd_stats(args=None):
    """Show summary statistics."""
    conn = sqlite3.connect(str(DB_PATH))

    total = conn.execute("SELECT COUNT(*) FROM history").fetchone()[0]
    print(f"\nTotal entries: {total:,}")

    print("\nBy source:")
    for source, count in conn.execute(
        "SELECT source, COUNT(*) FROM history GROUP BY source ORDER BY source"
    ):
        print(f"  {source}: {count:,}")

    r = conn.execute("SELECT MIN(timestamp_ms), MAX(timestamp_ms) FROM history").fetchone()
    if r[0]:
        print(f"\nDate range:")
        print(f"  {time.strftime('%Y-%m-%d', time.localtime(r[0] / 1000))} to "
              f"{time.strftime('%Y-%m-%d', time.localtime(r[1] / 1000))}")

    print("\nTop 10 projects:")
    for project, count in conn.execute(
        "SELECT project, COUNT(*) as c FROM history "
        "WHERE project IS NOT NULL GROUP BY project ORDER BY c DESC LIMIT 10"
    ):
        print(f"  {count:>6,}  {project}")

    conn.close()


def cmd_watch(args):
    """Continuous sync loop (for launchd/cron)."""
    interval = args.interval
    print(f"Watching every {interval}s (Ctrl-C to stop)...")
    while True:
        try:
            cmd_sync()
        except Exception as e:
            print(f"Error: {e}", file=sys.stderr)
        time.sleep(interval)


# --- CLI ---------------------------------------------------------------------

def main():
    p = argparse.ArgumentParser(prog="ai-hist", description="Sync & search AI CLI history in SQLite.")
    sub = p.add_subparsers(dest="command")

    sub.add_parser("sync", help="Import new entries from history files")

    s = sub.add_parser("search", help="Full-text search prompts")
    s.add_argument("query", nargs="+", help="Search terms")
    s.add_argument("--source", choices=["claude", "codex", "cursor", "relay"], help="Filter by source")
    s.add_argument("--project", help="Filter by project path (substring match)")
    s.add_argument("--limit", type=int, default=20, help="Max results (default: 20)")

    r = sub.add_parser("recent", help="Show most recent entries")
    r.add_argument("n", nargs="?", type=int, default=20, help="Number of entries (default: 20)")
    r.add_argument("--source", choices=["claude", "codex", "cursor", "relay"], help="Filter by source")
    r.add_argument("--project", help="Filter by project path (substring match)")

    sh = sub.add_parser("show", help="Show full details for an entry by ID")
    sh.add_argument("id", type=int, help="Entry ID (shown as #NNN in search/recent)")

    se = sub.add_parser("session", help="Show all prompts in a session")
    se.add_argument("session_id", help="Session ID")
    se.add_argument("--full", action="store_true", help="Show full prompt text (no truncation)")

    cx = sub.add_parser("context", help="Show entries around an ID (same session + nearby)")
    cx.add_argument("id", type=int, help="Entry ID to get context for")
    cx.add_argument("--window", type=int, default=5, help="Time window in minutes (default: 5)")

    sub.add_parser("stats", help="Show summary statistics")

    w = sub.add_parser("watch", help="Continuous sync loop")
    w.add_argument("--interval", type=int, default=60, help="Seconds between syncs (default: 60)")

    args = p.parse_args()
    cmds = {
        "sync": cmd_sync, "search": cmd_search, "recent": cmd_recent,
        "show": cmd_show, "session": cmd_session, "context": cmd_context,
        "stats": cmd_stats, "watch": cmd_watch,
    }

    if args.command in cmds:
        cmds[args.command](args)
    else:
        p.print_help()


if __name__ == "__main__":  # pragma: no cover
    main()
